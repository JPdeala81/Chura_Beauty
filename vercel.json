{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "frontend/dist", "buildCommand": "npm install && npm run build" }
    },
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/api(/|$)(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "^/((?!api).)*\\.(?:js|css|ico|png|jpg|jpeg|svg|woff|woff2|ttf|eot|map|json)$",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "^/assets(/.*)?$",
      "dest": "frontend/dist/assets$1"
    },
    {
      "src": "^(?!/api)(?:/?([^.]+|[^.]+\\.[^.]+))?/?$",
      "dest": "frontend/dist/index.html"
    }
  ]
}
